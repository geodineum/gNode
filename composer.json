{
    "name": "ncore/gsd",
    "description": "Geometric Service Daemon PHP Client",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "nCore Team",
            "email": "info@ncore.io"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-redis": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
