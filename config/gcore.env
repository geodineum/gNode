# ==============================================================================
# gCore Component Configuration
# ==============================================================================
# gCore-specific settings. Loaded after bootstrap.env.
#
# Location: /etc/geodineum/components/gCore/gcore.env
# Permissions: gnode:www-data 640 (PHP readable via www-data group)
#
# Note: Per-site credentials are resolved automatically by gNode-Client's
# CredentialResolver based on site_id. This file contains shared gCore settings.
# ==============================================================================

# ==============================================================================
# §1 gCORE PATHS
# ==============================================================================
GCORE_BASE_PATH="/opt/geodineum/gCore"
GCORE_LOG_PATH="/var/log/geodineum/gcore"
GCORE_CACHE_PATH="/var/cache/geodineum/gcore"

# ==============================================================================
# §2 gCORE DEBUG SETTINGS
# ==============================================================================
GCORE_DEBUG="false"
GCORE_DISPLAY_ERRORS="false"

# ==============================================================================
# §3 gCORE CACHE SETTINGS
# ==============================================================================
GCORE_CACHE_TTL="3600"
GCORE_CACHE_DRIVER="valkey"

# ==============================================================================
# §4 ADMIN CREDENTIAL REFERENCE (for ACL operations only)
# ==============================================================================
# Only used when gCore needs to perform admin operations (rare).
# Normal per-site operations use gnode_client_{site_id} credentials resolved
# automatically by CredentialResolver.

# VALKEY_ADMIN_PASSWORD_FILE="/etc/geodineum/credentials/valkey.password"
