# ==============================================================================
# Site-Specific Configuration Template
# ==============================================================================
# Per-site overrides. Copy this to /etc/geodineum/sites/{site_id}/site.env
#
# Location: /etc/geodineum/sites/{site_id}/site.env
# Permissions: gnode:www-data 640 (PHP readable via www-data group)
#
# Replace {site_id} with your actual site ID (e.g., my_app)
# ==============================================================================

# ==============================================================================
# §1 SITE IDENTITY
# ==============================================================================
GNODE_SITE_ID="{site_id}"
GNODE_ENVIRONMENT="testing"

# ==============================================================================
# §2 CREDENTIAL REFERENCE
# ==============================================================================
# The site's ValKey client password file. CredentialResolver will find this
# automatically, but you can explicitly specify if needed.

# VALKEY_PASSWORD_FILE="/etc/geodineum/credentials/valkey_client_{site_id}.password"
# VALKEY_USER="gnode_client_{site_id}"

# ==============================================================================
# §3 SITE-SPECIFIC OVERRIDES (Optional)
# ==============================================================================
# Override shared settings for this specific site

# GNODE_STREAM_PREFIX="gnode"
# GNODE_DEFAULT_ENVIRONMENT="staging"

# ==============================================================================
# §4 SITE CACHE SETTINGS (Optional)
# ==============================================================================
# GCORE_CACHE_TTL="1800"
