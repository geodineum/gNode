# ==============================================================================
# gNode Daemon Component Configuration
# ==============================================================================
# Daemon-specific settings NOT shared with other components.
#
# Location: /etc/geodineum/components/gnode-daemon/daemon.env
# Permissions: gnode:gnode 640 (daemon only - NOT readable by www-data/PHP)
#
# These settings are hot-reloadable via: kill -HUP $(pgrep gnode-daemon)
# ==============================================================================

# ==============================================================================
# §1 DAEMON CREDENTIAL REFERENCE
# ==============================================================================
# The daemon reads its password from file, NOT from environment variable.
# This ensures the password never appears in /proc/*/environ or ps output.

VALKEY_PASSWORD_FILE="/etc/geodineum/credentials/valkey_daemon.password"
VALKEY_USER="gnode_daemon"

# ==============================================================================
# §2 NODE CONFIGURATION
# ==============================================================================
GNODE_NODE_CONFIG_DIR="/etc/geodineum/components/gnode-daemon/nodes"

# ==============================================================================
# §3 TOPOLOGY (Hot-reloadable)
# ==============================================================================
# Discovery dimensions for spatial-hash bucket keys (19 out of 23 total).
# Total topology = 23D: 19 discovery dims (used for bucket key hashing) + 4 storage-only.
# Storage-only dims 19-22 (user_x, user_y, user_z, registration_order) are stored per
# entity and queryable via range filters, but excluded from the bucket key to avoid scatter.
GNODE_DIMENSIONS="19"

# ==============================================================================
# §4 THREADING (Hot-reloadable)
# ==============================================================================
GNODE_THREADS="auto"
GNODE_MAX_THREADS="16"

# ==============================================================================
# §5 BATCH PROCESSING (Hot-reloadable)
# ==============================================================================
GNODE_INITIAL_BATCH_SIZE="250"
GNODE_MAX_BATCH_SIZE="500"
GNODE_MIN_BATCH_SIZE="50"

# ==============================================================================
# §6 STREAM MANAGEMENT (Hot-reloadable)
# ==============================================================================
GNODE_STREAM_MAX_LENGTH="10000"
GNODE_TRIM_INTERVAL_SECS="60"
GNODE_APPROXIMATE_TRIM="true"
GNODE_STREAM_REFRESH_SECS="60"

# ==============================================================================
# §7 BACKOFF & TIMING (Hot-reloadable)
# ==============================================================================
GNODE_BASE_BACKOFF_MS="100"
GNODE_MAX_BACKOFF_MS="1000"
GNODE_IDLE_TIME_MS="30000"
GNODE_PENDING_CHECK_MS="5000"

# ==============================================================================
# §8 CIRCUIT BREAKER (Hot-reloadable)
# ==============================================================================
GNODE_CB_THRESHOLD="5"
GNODE_CB_COOLDOWN_SECS="30"

# ==============================================================================
# §9 CONSUMER GROUPS (Hot-reloadable)
# ==============================================================================
GNODE_CONSUMER_PREFIX="consumer-"
GNODE_BLOCK_TIMEOUT_MS="1000"
GNODE_CLAIM_INTERVAL_MS="5000"
GNODE_BATCH_ACKNOWLEDGE="true"
GNODE_MAX_PENDING_CLAIM="50"

# ── Extension security ──────────────────────────────────────────────────────
# Signed-extensions-only mode. When on, EVERY extension source — including the
# per-path dev overrides (GNODE_EXT_<NAME>_PATH / --ext-path) — must carry a
# valid author Ed25519 signature, not just GNODE_EXT_DIR. We ship signed
# extensions (gNode-CMS et al.), so production defaults ON; set to 0 only for
# local extension development against unsigned working copies.
GNODE_SIGNED_EXT_ONLY="1"
